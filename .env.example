# =============================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE - SGI
# =============================================================================
# NÃO faça commit deste arquivo com valores reais preenchidos.
# Configure as variáveis abaixo via:
#   - Painel de hospedagem (variáveis de ambiente do PHP/Apache)
#   - Arquivo .htaccess com SetEnv (SOMENTE fora do web root ou protegido)
#   - php.ini / .user.ini (recomendado em hospedagem compartilhada)
# =============================================================================

# Ambiente da aplicação: production | development | testing
APP_ENV=production

# Chave de criptografia das sessões (mínimo 32 chars aleatórios)
# Gere com: php -r "echo bin2hex(random_bytes(32));"
APP_ENCRYPTION_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA

# Banco de dados
DB_HOST=localhost
DB_USER=seu_usuario_banco
DB_PASS=sua_senha_banco
DB_NAME=seu_banco_de_dados

# Integração Simplex (opcional)
SIMPLEX_URL=https://app.simplexon.tec.br/api/1.1/wf
SIMPLEX_TOKEN=

# =============================================================================
# COMO CONFIGURAR EM HOSPEDAGEM COMPARTILHADA (cPanel/Hostinger etc.)
# =============================================================================
# Opção 1: Adicionar ao .htaccess (FORA da diretiva de rewrite):
#   SetEnv APP_ENV production
#   SetEnv DB_PASS sua_senha
#
# Opção 2: Criar arquivo /home/usuario/.user.ini:
#   [PHP]
#   auto_prepend_file = /home/usuario/env_loader.php
#
# Opção 3: Usar o painel de controle da hospedagem (preferível).
# =============================================================================
